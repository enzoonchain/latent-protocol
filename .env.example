# ─────────────────────────────────────────────
# Agent Kickbacks — Environment Variables
# ─────────────────────────────────────────────
# Copy to .env and fill in your values.

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Database (Railway Postgres) ──
# Railway injects this automatically when you attach a Postgres plugin.
# Local dev (docker compose) default shown below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_kickbacks

# ── x402 / Payments ──
# Turn on payment-gating for POST /ad/request (default off until a facilitator
# is configured and tested on Base Sepolia — see task 1.1.6).
X402_ENABLED=false
X402_AD_PRICE=$0.001
# Your marketplace treasury wallet on Base
EVM_ADDRESS=0xYourTreasuryWalletAddress
EVM_PRIVATE_KEY=your-private-key-for-payouts
FACILITATOR_URL=https://x402.org/facilitator

# ── Base Chain ──
# eip155:8453 = Base Mainnet, eip155:84532 = Base Sepolia
EVM_NETWORK=eip155:84532

# ── USDC Contract ──
# Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ── Plugin ──
# User's Base wallet address (set via hermes config set ads.wallet)
# ADS_WALLET=0xYourWallet

# ── Rate Limiting ──
MAX_IMPRESSIONS_PER_USER_PER_DAY=100
MAX_IMPRESSIONS_PER_SESSION=20
PAYOUT_THRESHOLD_USDC=5.00

# ── Integrity / Anti-Fraud ──
# Secret for signing impression tokens. MUST be set to a long random value in
# production (a dev default is used if empty).
IMPRESSION_SIGNING_SECRET=
IMPRESSION_TOKEN_TTL_SECONDS=300
IMPRESSION_REPLAY_WINDOW_SECONDS=60
CLICK_MIN_VIEW_SECONDS=2
